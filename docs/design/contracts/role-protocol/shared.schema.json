{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sv-playbook:role-protocol:shared:1.0.0",
  "title": "SV Playbook Shared Role Protocol Types",
  "description": "Strict schemas for shared types used across role protocol artifacts. All $ref values are internal and resolvable.",
  "$defs": {
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "value": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "minLength": 64,
          "maxLength": 64
        }
      },
      "required": ["algorithm", "value"]
    },
    "artifact-ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "type": "string",
          "enum": [
            "acceptance-relay",
            "advisor-recommendation",
            "arbiter-ruling",
            "change-contract",
            "code-snapshot",
            "correction-record",
            "decision-record",
            "dispatch-decision",
            "handoff-report",
            "intent-contract",
            "investigation-report",
            "operational-resolution",
            "patch-proposal",
            "plan-proposal",
            "refutation-report",
            "review-verdict",
            "sourcing-assessment",
            "sprint-report",
            "status-digest",
            "task-spec"
          ]
        },
        "artifact_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 1
        },
        "version_digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "required": ["artifact_kind", "artifact_id", "version_digest"]
    },
    "requirement-ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_id": {
          "type": "string",
          "minLength": 1
        },
        "requirement_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 1
        },
        "contract_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["contract_id", "requirement_id", "contract_version"]
    },
    "subject": {
      "description": "Discriminated subject indicating the kind of artifact or requirement a deviation or correction targets.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subject_kind": {
          "type": "string",
          "enum": ["requirement", "artifact"]
        },
        "subject_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/requirement-ref"
            },
            {
              "$ref": "#/$defs/artifact-ref"
            }
          ]
        }
      },
      "required": ["subject_kind", "subject_ref"],
      "allOf": [
        {
          "if": {
            "properties": {
              "subject_kind": {
                "const": "requirement"
              }
            },
            "required": ["subject_kind"]
          },
          "then": {
            "properties": {
              "subject_ref": {
                "$ref": "#/$defs/requirement-ref"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "subject_kind": {
                "const": "artifact"
              }
            },
            "required": ["subject_kind"]
          },
          "then": {
            "properties": {
              "subject_ref": {
                "$ref": "#/$defs/artifact-ref"
              }
            }
          }
        }
      ]
    },
    "evidence-locator": {
      "description": "Structured pointer into an artifact. The locator_kind const determines interpretation.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "locator_kind": {
              "const": "artifact-root"
            }
          },
          "required": ["locator_kind"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "locator_kind": {
              "const": "file-range"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "start_line": {
              "type": "integer",
              "minimum": 1
            },
            "end_line": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": ["locator_kind", "path", "start_line", "end_line"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "locator_kind": {
              "const": "json-pointer"
            },
            "pointer": {
              "type": "string",
              "pattern": "^(?:/(?:[^~]|~[01])*)*$",
              "minLength": 1
            }
          },
          "required": ["locator_kind", "pointer"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "locator_kind": {
              "const": "check-id"
            },
            "id": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
              "minLength": 1
            }
          },
          "required": ["locator_kind", "id"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "locator_kind": {
              "const": "event-id"
            },
            "id": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
              "minLength": 1
            }
          },
          "required": ["locator_kind", "id"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "locator_kind": {
              "const": "git-object"
            },
            "digest": {
              "$ref": "#/$defs/digest"
            }
          },
          "required": ["locator_kind", "digest"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "description": "Half-open [start, end) offsets into the complete canonical byte representation of the referenced immutable artifact.",
          "properties": {
            "locator_kind": {
              "const": "byte-range"
            },
            "start": {
              "type": "integer",
              "minimum": 0
            },
            "end": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": ["locator_kind", "start", "end"]
        }
      ]
    },
    "evidence-ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence_type": {
          "type": "string",
          "enum": [
            "check-output",
            "test-result",
            "file-content",
            "diff",
            "mechanical-observation",
            "log-entry",
            "review-finding",
            "diagnostic-output"
          ]
        },
        "artifact_ref": {
          "$ref": "#/$defs/artifact-ref"
        },
        "locator": {
          "$ref": "#/$defs/evidence-locator"
        }
      },
      "required": ["evidence_type", "artifact_ref", "locator"]
    },
    "mechanical-fact-ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fact_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 1
        },
        "fact_domain": {
          "type": "string",
          "enum": [
            "store",
            "git",
            "checks",
            "config",
            "runtime-state",
            "capability-result"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time",
          "minLength": 1
        },
        "source_digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "required": [
        "fact_id",
        "fact_domain",
        "locator",
        "observed_at",
        "source_digest"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provenance_kind": {
          "type": "string",
          "enum": [
            "human-stated",
            "human-confirmed",
            "runtime-mechanical",
            "agent-judgment",
            "system-inferred",
            "agent-proposed"
          ]
        },
        "agent_role_id": {
          "type": ["string", "null"]
        },
        "session_id": {
          "type": ["string", "null"]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "minLength": 1
        },
        "confirmed_by": {
          "type": ["string", "null"]
        }
      },
      "required": [
        "provenance_kind",
        "agent_role_id",
        "session_id",
        "timestamp",
        "confirmed_by"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "provenance_kind": {
                "const": "runtime-mechanical"
              }
            },
            "required": ["provenance_kind"]
          },
          "then": {
            "properties": {
              "agent_role_id": {
                "const": null
              },
              "session_id": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "provenance_kind": {
                "enum": ["agent-judgment", "agent-proposed"]
              }
            },
            "required": ["provenance_kind"]
          },
          "then": {
            "properties": {
              "agent_role_id": {
                "type": "string",
                "minLength": 1
              },
              "session_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "provenance_kind": {
                "enum": ["human-stated", "human-confirmed", "system-inferred"]
              }
            },
            "required": ["provenance_kind"]
          },
          "then": {
            "properties": {
              "agent_role_id": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "provenance_kind": {
                "const": "human-confirmed"
              }
            },
            "required": ["provenance_kind"]
          },
          "then": {
            "properties": {
              "confirmed_by": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "provenance_kind": {
                "not": {
                  "const": "human-confirmed"
                }
              }
            }
          },
          "then": {
            "properties": {
              "confirmed_by": {
                "const": null
              }
            }
          }
        }
      ]
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "risk_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "likelihood": {
          "type": "string",
          "enum": ["unlikely", "possible", "likely", "certain"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "mitigation": {
          "type": ["string", "null"],
          "minLength": 1
        }
      },
      "required": [
        "risk_id",
        "severity",
        "likelihood",
        "description",
        "mitigation"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "severity": {
                "enum": ["high", "critical"]
              }
            },
            "required": ["severity"]
          },
          "then": {
            "properties": {
              "mitigation": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "deviation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deviation_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 1
        },
        "subject": {
          "$ref": "#/$defs/subject"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "risk_assessment": {
          "$ref": "#/$defs/risk"
        },
        "affected_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requirement-ref"
          },
          "uniqueItems": true
        }
      },
      "required": [
        "deviation_id",
        "subject",
        "description",
        "reason",
        "risk_assessment",
        "affected_requirements"
      ]
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "escalation_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 1
        },
        "escalation_class": {
          "type": "string",
          "enum": [
            "capability-gap",
            "authority-boundary",
            "ambiguous-input",
            "irreversible-decision-needed",
            "contract-violation",
            "correction-exhausted",
            "scope-overshoot",
            "semantic-disagreement",
            "systemic-pattern",
            "deadlock"
          ]
        },
        "cause": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "what_is_needed": {
          "type": "string",
          "minLength": 1
        },
        "related_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact-ref"
          },
          "uniqueItems": true
        },
        "attempt_history": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/correction-record"
              },
              "uniqueItems": true,
              "minItems": 1
            }
          ]
        }
      },
      "required": [
        "escalation_id",
        "escalation_class",
        "cause",
        "context",
        "what_is_needed",
        "related_artifacts",
        "attempt_history"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "escalation_class": {
                "const": "correction-exhausted"
              }
            },
            "required": ["escalation_class"]
          },
          "then": {
            "properties": {
              "attempt_history": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "escalation_class": {
                "not": {
                  "const": "correction-exhausted"
                }
              }
            },
            "required": ["escalation_class"]
          },
          "then": {
            "properties": {
              "attempt_history": {
                "const": null
              }
            }
          }
        }
      ]
    },
    "correction-record": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 1
        },
        "subject": {
          "$ref": "#/$defs/subject"
        },
        "cause_summary": {
          "type": "string",
          "minLength": 1
        },
        "cause_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/evidence-ref"
              },
              {
                "$ref": "#/$defs/mechanical-fact-ref"
              }
            ]
          }
        },
        "revision_reason": {
          "type": "string",
          "minLength": 1
        },
        "semantic_diff": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": ["success", "failure", "partial"]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence-ref"
          },
          "uniqueItems": true
        }
      },
      "required": [
        "attempt_id",
        "subject",
        "cause_summary",
        "cause_refs",
        "revision_reason",
        "semantic_diff",
        "result",
        "evidence"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "result": {
                "enum": ["failure", "partial"]
              }
            },
            "required": ["result"]
          },
          "then": {
            "properties": {
              "evidence": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "question_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 1
        },
        "question_type": {
          "type": "string",
          "enum": [
            "clarification",
            "decision-request",
            "information-request",
            "confirmation"
          ]
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "what_is_needed": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["question_id", "question_type", "context", "what_is_needed"]
    }
  }
}
