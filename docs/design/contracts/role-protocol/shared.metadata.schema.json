{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sv-playbook:role-protocol:shared-metadata:1.0.0",
  "title": "SV Playbook Shared Metadata Schema",
  "description": "Strict schema for shared.metadata-v4.json: the metadata protocol that governs how the shared role-protocol types schema is validated, canonicalized, and held invariant.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "metadata_version": {
      "const": "1.0.0"
    },
    "schema_id": {
      "const": "urn:sv-playbook:role-protocol:shared:1.0.0",
      "description": "The $id of the shared role-protocol schema that this metadata document governs."
    },
    "canonicalization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "const": "whole-artifact"
        },
        "scheme": {
          "const": "RFC 8785"
        },
        "preconditions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "json_conformance": {
              "type": "string",
              "minLength": 1
            },
            "rfc8785_unicode": {
              "type": "string",
              "minLength": 1
            },
            "validation_order": {
              "type": "string",
              "minLength": 1
            },
            "numeric_encoding": {
              "type": "string",
              "minLength": 1
            },
            "artifact_encoding": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "json_conformance",
            "rfc8785_unicode",
            "validation_order",
            "numeric_encoding",
            "artifact_encoding"
          ]
        },
        "rules": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "description",
        "scope",
        "scheme",
        "preconditions",
        "rules",
        "rationale"
      ]
    },
    "validator_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "https://json-schema.org/draft/2020-12/schema"
        },
        "validator": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "library": {
              "const": "ajv"
            },
            "minimum_version": {
              "const": "8.0.0"
            },
            "options": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "strict": {
                  "const": true
                },
                "strictRequired": {
                  "const": true
                },
                "strictNumbers": {
                  "const": true
                },
                "strictTypes": {
                  "const": true
                },
                "strictTuples": {
                  "const": true
                },
                "allErrors": {
                  "const": true
                },
                "addUsedSchema": {
                  "const": false
                },
                "validateSchema": {
                  "const": true
                }
              },
              "required": [
                "strict",
                "strictRequired",
                "strictNumbers",
                "strictTypes",
                "strictTuples",
                "allErrors",
                "addUsedSchema",
                "validateSchema"
              ]
            }
          },
          "required": ["library", "minimum_version", "options"]
        },
        "formats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "plugin": {
              "const": "ajv-formats"
            },
            "mode": {
              "const": "full"
            },
            "description": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["plugin", "mode", "description"]
        },
        "schema_fixtures": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "minLength": 1
            },
            "positive": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/schema-fixture"
              }
            },
            "negative": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/schema-fixture"
              }
            }
          },
          "required": ["description", "positive", "negative"]
        },
        "runtime_fixtures": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "minLength": 1
            },
            "positive": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/runtime-fixture"
              }
            },
            "negative": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/runtime-fixture"
              }
            }
          },
          "required": ["description", "positive", "negative"]
        }
      },
      "required": [
        "schema_version",
        "validator",
        "formats",
        "schema_fixtures",
        "runtime_fixtures"
      ]
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/invariant"
      }
    }
  },
  "required": [
    "metadata_version",
    "schema_id",
    "canonicalization",
    "validator_contract",
    "invariants"
  ],
  "$defs": {
    "schema-fixture": {
      "type": "object",
      "additionalProperties": false,
      "description": "A fixture that tests schema-level structural constraints. The value field may be any JSON; the target pointer selects which schema definition validates it.",
      "properties": {
        "fixture_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1,
          "description": "JSON Pointer to the schema definition that validates this fixture\u0027s value, e.g. #/$defs/digest."
        },
        "value": {
          "description": "Any JSON value. The schema selected by target validates this."
        }
      },
      "required": ["fixture_id", "description", "target", "value"]
    },
    "runtime-fixture": {
      "description": "A fixture that tests cross-field invariants and runtime behavior. Discriminated structurally by the invariant_id const value.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "description": "file-byte-range-ordering fixture: the invariant requires no additional context.",
          "properties": {
            "fixture_id": {
              "type": "string",
              "minLength": 1
            },
            "invariant_id": {
              "const": "file-byte-range-ordering"
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "target": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "description": "Any JSON value. The input to the invariant check."
            }
          },
          "required": ["fixture_id", "invariant_id", "target", "value"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "description": "digest-verification-canonical-bytes fixture: the invariant requires a resolved artifact JSON value as context.",
          "properties": {
            "fixture_id": {
              "type": "string",
              "minLength": 1
            },
            "invariant_id": {
              "const": "digest-verification-canonical-bytes"
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "target": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "description": "Any JSON value. The input to the invariant check."
            },
            "context": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "resolved_artifact_json": {
                  "description": "Any JSON value representing the resolved artifact."
                }
              },
              "required": ["resolved_artifact_json"]
            }
          },
          "required": [
            "fixture_id",
            "invariant_id",
            "target",
            "value",
            "context"
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "description": "evidence-locator-compatibility fixture: the invariant requires a list of allowed locator kinds as context.",
          "properties": {
            "fixture_id": {
              "type": "string",
              "minLength": 1
            },
            "invariant_id": {
              "const": "evidence-locator-compatibility"
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "target": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "description": "Any JSON value. The input to the invariant check."
            },
            "context": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "allowed_locator_kinds": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "description": "The locator kinds that are compatible under this invariant."
                }
              },
              "required": ["allowed_locator_kinds"]
            }
          },
          "required": [
            "fixture_id",
            "invariant_id",
            "target",
            "value",
            "context"
          ]
        }
      ]
    },
    "invariant": {
      "type": "object",
      "additionalProperties": false,
      "description": "A single metadata invariant: a constraint that must hold across all valid instances of the governed schema.",
      "properties": {
        "invariant_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 1,
          "description": "Unique, stable identifier for this invariant."
        },
        "applies_to": {
          "type": "string",
          "minLength": 1,
          "description": "What parts of the schema or artifact space this invariant covers."
        },
        "statement": {
          "type": "string",
          "minLength": 1,
          "description": "Formal statement of the invariant condition."
        },
        "enforcement": {
          "type": "string",
          "enum": ["runtime-check", "semantic-review", "workflow-check"],
          "description": "How this invariant is enforced."
        },
        "evidence_requirement": {
          "type": "string",
          "minLength": 1,
          "description": "What evidence is required to verify this invariant."
        },
        "decision_source": {
          "$ref": "urn:sv-playbook:role-protocol:shared:1.0.0#/$defs/artifact-ref",
          "description": "The artifact that established this invariant."
        }
      },
      "required": [
        "invariant_id",
        "applies_to",
        "statement",
        "enforcement",
        "evidence_requirement",
        "decision_source"
      ]
    }
  }
}
