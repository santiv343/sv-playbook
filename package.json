{
  "name": "sv-playbook",
  "version": "0.1.0",
  "description": "End-to-end methodology for agent-driven software development: a markdown constitution plus a verifier CLI.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sv-playbook": "./bin/sv-playbook.js"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "files": [
    "bin",
    "dist",
    "content",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc && node scripts/copy-serve-assets.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "npm run build && eslint . && node dist/check/source-policy-cli.js",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "test:quiet": "npm run build && node --test --test-reporter dot \"dist/**/*.test.js\"",
    "verify": "npm run build && node dist/verification/cli.js"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "json-canonicalize": "^2.0.0",
    "uuid": "^14.0.1"
  }
}
